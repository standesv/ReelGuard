<resources>
    <!-- App -->
    <string name="app_name">ReelGuard</string>
    <string name="accessibility_service_label">ReelGuard — Reel Blocker</string>
    <string name="accessibility_service_description">ReelGuard monitors Reels on Instagram, YouTube Shorts, TikTok and other apps to block them when your daily quota is reached. No data is sent outside your phone.</string>

    <!-- Onboarding - Welcome -->
    <string name="onboarding_welcome_title">Welcome to ReelGuard</string>
    <string name="onboarding_welcome_step1">ReelGuard blocks Reels on Instagram, YouTube Shorts, TikTok, Facebook, Snapchat and more.</string>
    <string name="onboarding_welcome_step2">Set a daily quota (count or duration) and the app automatically blocks when it\'s reached.</string>
    <string name="onboarding_welcome_step3">All your data stays on your phone — no server, no account required.</string>

    <!-- Onboarding - Accessibility -->
    <string name="onboarding_accessibility_title">Permission 1/2 — Accessibility Service</string>
    <string name="onboarding_accessibility_step1">Tap the button below to open accessibility settings.</string>
    <string name="onboarding_accessibility_step2">Look for the "Downloaded apps" or "Installed services" section.</string>
    <string name="onboarding_accessibility_step3">Tap "ReelGuard".</string>
    <string name="onboarding_accessibility_step4">Enable the toggle at the top and confirm by tapping "Allow".</string>
    <string name="onboarding_accessibility_note">⚠️ On Samsung: Settings → Accessibility → Installed apps → ReelGuard. On Pixel: Settings → Accessibility → ReelGuard.</string>
    <string name="onboarding_accessibility_button">Open accessibility settings</string>

    <!-- Onboarding - Overlay -->
    <string name="onboarding_overlay_title">Permission 2/2 — Display over other apps</string>
    <string name="onboarding_overlay_step1">Tap the button below.</string>
    <string name="onboarding_overlay_step2">Find "ReelGuard" in the list and tap it.</string>
    <string name="onboarding_overlay_step3">Enable "Allow display over other apps".</string>
    <string name="onboarding_overlay_note">⚠️ On some devices this is called "Appear on top" or "Draw over other apps".</string>
    <string name="onboarding_overlay_button">Open display settings</string>

    <!-- Onboarding - Config -->
    <string name="onboarding_config_title">Configure your quota</string>
    <string name="onboarding_config_step1">Open Settings (⚙️ icon in the top right of the dashboard).</string>
    <string name="onboarding_config_step2">Enable "Time quota" and set it to 15 minutes — a good starting point.</string>
    <string name="onboarding_config_step3">Or enable "Count quota" if you prefer to limit the number of Reels.</string>
    <string name="onboarding_config_step4">Tap "Save".</string>
    <string name="onboarding_config_note">You\'ll receive a warning at 80% of your quota. You can change these settings at any time.</string>

    <!-- Onboarding - Ready -->
    <string name="onboarding_ready_title">Let\'s go!</string>
    <string name="onboarding_ready_step1">ReelGuard is now monitoring your apps.</string>
    <string name="onboarding_ready_step2">The dashboard shows your usage for today.</string>
    <string name="onboarding_ready_step3">Enable Focus Mode to completely block Reels for a set duration.</string>
    <string name="onboarding_ready_note">If blocking doesn\'t work, check that both permissions are granted (red banner = missing permission).</string>

