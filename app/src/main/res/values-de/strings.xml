<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App -->
    <string name="app_name">ReelGuard</string>
    <string name="accessibility_service_label">ReelGuard — Reels-Blocker</string>
    <string name="accessibility_service_description">ReelGuard überwacht Reels auf Instagram, YouTube Shorts, TikTok und anderen Apps und blockiert sie, wenn dein tägliches Kontingent erreicht ist. Es werden keine Daten außerhalb deines Telefons gesendet.</string>

    <!-- Onboarding - Willkommen -->
    <string name="onboarding_welcome_title">Willkommen bei ReelGuard</string>
    <string name="onboarding_welcome_step1">ReelGuard blockiert Reels auf Instagram, YouTube Shorts, TikTok, Facebook, Snapchat und mehr.</string>
    <string name="onboarding_welcome_step2">Lege ein tägliches Kontingent fest (Anzahl oder Dauer) und die App blockiert automatisch, wenn es erreicht ist.</string>
    <string name="onboarding_welcome_step3">Alle deine Daten bleiben auf deinem Telefon — kein Server, kein Konto erforderlich.</string>

    <!-- Onboarding - Barrierefreiheit -->
    <string name="onboarding_accessibility_title">Berechtigung 1/2 — Bedienungshilfen</string>
    <string name="onboarding_accessibility_step1">Tippe auf die Schaltfläche unten, um die Bedienungshilfen-Einstellungen zu öffnen.</string>
    <string name="onboarding_accessibility_step2">Suche nach dem Abschnitt „Heruntergeladene Apps" oder „Installierte Dienste".</string>
    <string name="onboarding_accessibility_step3">Tippe auf „ReelGuard".</string>
    <string name="onboarding_accessibility_step4">Aktiviere den Schalter oben und bestätige mit „Zulassen".</string>
    <string name="onboarding_accessibility_note">⚠️ Auf Samsung: Einstellungen → Bedienungshilfen → Installierte Apps → ReelGuard. Auf Pixel: Einstellungen → Bedienungshilfen → ReelGuard.</string>
    <string name="onboarding_accessibility_button">Bedienungshilfen öffnen</string>

    <!-- Onboarding - Einblendung -->
    <string name="onboarding_overlay_title">Berechtigung 2/2 — Über anderen Apps anzeigen</string>
    <string name="onboarding_overlay_step1">Tippe auf die Schaltfläche unten.</string>
    <string name="onboarding_overlay_step2">Suche „ReelGuard" in der Liste und tippe darauf.</string>
    <string name="onboarding_overlay_step3">Aktiviere „Über anderen Apps anzeigen".</string>
    <string name="onboarding_overlay_note">⚠️ Auf manchen Geräten heißt diese Option „Im Vordergrund erscheinen" oder „Über anderen Apps zeichnen".</string>
    <string name="onboarding_overlay_button">Anzeigeeinstellungen öffnen</string>

    <!-- Onboarding - Konfiguration -->
    <string name="onboarding_config_title">Kontingent konfigurieren</string>
    <string name="onboarding_config_step1">Öffne Einstellungen (⚙️-Symbol oben rechts im Dashboard).</string>
    <string name="onboarding_config_step2">Aktiviere „Zeitkontingent" und stelle es auf 15 Minuten ein — ein guter Ausgangspunkt.</string>
    <string name="onboarding_config_step3">Oder aktiviere „Anzahlkontingent", wenn du lieber die Anzahl der Reels begrenzen möchtest.</string>
    <string name="onboarding_config_step4">Tippe auf „Speichern".</string>
    <string name="onboarding_config_note">Du erhältst eine Warnung bei 80 % deines Kontingents. Du kannst diese Einstellungen jederzeit ändern.</string>

    <!-- Onboarding - Bereit -->
    <string name="onboarding_ready_title">Los geht\'s!</string>
    <string name="onboarding_ready_step1">ReelGuard überwacht jetzt deine Apps.</string>
    <string name="onboarding_ready_step2">Das Dashboard zeigt deine heutige Nutzung.</string>
    <string name="onboarding_ready_step3">Aktiviere den Fokusmodus, um Reels für eine bestimmte Dauer vollständig zu blockieren.</string>
    <string name="onboarding_ready_note">Wenn die Blockierung nicht funktioniert, prüfe, ob beide Berechtigungen erteilt wurden (roter Banner = fehlende Berechtigung).</string>

