<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App -->
    <string name="app_name">ReelGuard</string>
    <string name="accessibility_service_label">ReelGuard — Bloqueur de Reels</string>
    <string name="accessibility_service_description">ReelGuard surveille les Reels sur Instagram, YouTube Shorts, TikTok et d\'autres apps pour les bloquer lorsque votre quota quotidien est atteint. Aucune donnée n\'est envoyée en dehors de votre téléphone.</string>

    <!-- Onboarding - Bienvenue -->
    <string name="onboarding_welcome_title">Bienvenue sur ReelGuard</string>
    <string name="onboarding_welcome_step1">ReelGuard bloque les Reels sur Instagram, YouTube Shorts, TikTok, Facebook, Snapchat et bien d\'autres.</string>
    <string name="onboarding_welcome_step2">Définissez un quota quotidien (nombre ou durée) et l\'app bloque automatiquement quand il est atteint.</string>
    <string name="onboarding_welcome_step3">Toutes vos données restent sur votre téléphone — pas de serveur, pas de compte requis.</string>

    <!-- Onboarding - Accessibilité -->
    <string name="onboarding_accessibility_title">Permission 1/2 — Service d\'accessibilité</string>
    <string name="onboarding_accessibility_step1">Appuyez sur le bouton ci-dessous pour ouvrir les paramètres d\'accessibilité.</string>
    <string name="onboarding_accessibility_step2">Cherchez la section « Applications téléchargées » ou « Services installés ».</string>
    <string name="onboarding_accessibility_step3">Appuyez sur « ReelGuard ».</string>
    <string name="onboarding_accessibility_step4">Activez l\'interrupteur en haut, puis confirmez en appuyant sur « Autoriser ».</string>
    <string name="onboarding_accessibility_note">⚠️ Sur Samsung : Paramètres → Accessibilité → Applications installées → ReelGuard. Sur Pixel : Paramètres → Accessibilité → ReelGuard.</string>
    <string name="onboarding_accessibility_button">Ouvrir les paramètres d\'accessibilité</string>

    <!-- Onboarding - Superposition -->
    <string name="onboarding_overlay_title">Permission 2/2 — Afficher par-dessus les autres apps</string>
    <string name="onboarding_overlay_step1">Appuyez sur le bouton ci-dessous.</string>
    <string name="onboarding_overlay_step2">Trouvez « ReelGuard » dans la liste et appuyez dessus.</string>
    <string name="onboarding_overlay_step3">Activez « Autoriser l\'affichage par-dessus les autres apps ».</string>
    <string name="onboarding_overlay_note">⚠️ Sur certains appareils, cette option s\'appelle « Apparaître au premier plan » ou « Afficher au-dessus des autres apps ».</string>
    <string name="onboarding_overlay_button">Ouvrir les paramètres d\'affichage</string>

    <!-- Onboarding - Config -->
    <string name="onboarding_config_title">Configurez votre quota</string>
    <string name="onboarding_config_step1">Ouvrez les Paramètres (icône ⚙️ en haut à droite du tableau de bord).</string>
    <string name="onboarding_config_step2">Activez « Quota temps » et réglez-le sur 15 minutes — un bon point de départ.</string>
    <string name="onboarding_config_step3">Ou activez « Quota nombre » si vous préférez limiter le nombre de Reels.</string>
    <string name="onboarding_config_step4">Appuyez sur « Enregistrer ».</string>
    <string name="onboarding_config_note">Vous recevrez un avertissement à 80 % de votre quota. Vous pouvez modifier ces paramètres à tout moment.</string>

    <!-- Onboarding - Prêt -->
    <string name="onboarding_ready_title">C\'est parti !</string>
    <string name="onboarding_ready_step1">ReelGuard surveille maintenant vos applications.</string>
    <string name="onboarding_ready_step2">Le tableau de bord affiche votre consommation du jour.</string>
    <string name="onboarding_ready_step3">Activez le Mode Focus pour bloquer complètement les Reels pendant une durée définie.</string>
    <string name="onboarding_ready_note">Si le blocage ne fonctionne pas, vérifiez que les deux permissions sont accordées (bandeau rouge = permission manquante).</string>

