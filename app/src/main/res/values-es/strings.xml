<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- App -->
    <string name="app_name">ReelGuard</string>
    <string name="accessibility_service_label">ReelGuard — Bloqueador de Reels</string>
    <string name="accessibility_service_description">ReelGuard supervisa los Reels en Instagram, YouTube Shorts, TikTok y otras apps para bloquearlos cuando se alcanza tu cuota diaria. No se envía ningún dato fuera de tu teléfono.</string>

    <!-- Onboarding - Bienvenida -->
    <string name="onboarding_welcome_title">Bienvenido a ReelGuard</string>
    <string name="onboarding_welcome_step1">ReelGuard bloquea los Reels en Instagram, YouTube Shorts, TikTok, Facebook, Snapchat y más.</string>
    <string name="onboarding_welcome_step2">Establece una cuota diaria (cantidad o duración) y la app bloquea automáticamente cuando se alcanza.</string>
    <string name="onboarding_welcome_step3">Todos tus datos se quedan en tu teléfono — sin servidor, sin cuenta requerida.</string>

    <!-- Onboarding - Accesibilidad -->
    <string name="onboarding_accessibility_title">Permiso 1/2 — Servicio de accesibilidad</string>
    <string name="onboarding_accessibility_step1">Pulsa el botón de abajo para abrir los ajustes de accesibilidad.</string>
    <string name="onboarding_accessibility_step2">Busca la sección «Apps descargadas» o «Servicios instalados».</string>
    <string name="onboarding_accessibility_step3">Pulsa «ReelGuard».</string>
    <string name="onboarding_accessibility_step4">Activa el interruptor superior y confirma pulsando «Permitir».</string>
    <string name="onboarding_accessibility_note">⚠️ En Samsung: Ajustes → Accesibilidad → Apps instaladas → ReelGuard. En Pixel: Ajustes → Accesibilidad → ReelGuard.</string>
    <string name="onboarding_accessibility_button">Abrir ajustes de accesibilidad</string>

    <!-- Onboarding - Superposición -->
    <string name="onboarding_overlay_title">Permiso 2/2 — Mostrar sobre otras apps</string>
    <string name="onboarding_overlay_step1">Pulsa el botón de abajo.</string>
    <string name="onboarding_overlay_step2">Encuentra «ReelGuard» en la lista y pulsa sobre él.</string>
    <string name="onboarding_overlay_step3">Activa «Permitir mostrar sobre otras apps».</string>
    <string name="onboarding_overlay_note">⚠️ En algunos dispositivos se llama «Aparecer encima» o «Dibujar sobre otras apps».</string>
    <string name="onboarding_overlay_button">Abrir ajustes de visualización</string>

    <!-- Onboarding - Configuración -->
    <string name="onboarding_config_title">Configura tu cuota</string>
    <string name="onboarding_config_step1">Abre Ajustes (icono ⚙️ en la parte superior derecha del panel).</string>
    <string name="onboarding_config_step2">Activa «Cuota de tiempo» y configúrala en 15 minutos — un buen punto de partida.</string>
    <string name="onboarding_config_step3">O activa «Cuota de cantidad» si prefieres limitar el número de Reels.</string>
    <string name="onboarding_config_step4">Pulsa «Guardar».</string>
    <string name="onboarding_config_note">Recibirás una advertencia al 80 % de tu cuota. Puedes cambiar estos ajustes en cualquier momento.</string>

    <!-- Onboarding - Listo -->
    <string name="onboarding_ready_title">¡Vamos allá!</string>
    <string name="onboarding_ready_step1">ReelGuard ahora supervisa tus aplicaciones.</string>
    <string name="onboarding_ready_step2">El panel muestra tu uso de hoy.</string>
    <string name="onboarding_ready_step3">Activa el Modo Foco para bloquear completamente los Reels durante un tiempo definido.</string>
    <string name="onboarding_ready_note">Si el bloqueo no funciona, comprueba que ambos permisos están concedidos (banner rojo = permiso faltante).</string>

